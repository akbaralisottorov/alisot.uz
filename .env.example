# Database connection URL (PostgreSQL - Neon.tech is highly recommended)
# Example: postgresql://username:password@ep-host-name.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://username:password@ep-host-name.region.aws.neon.tech/neondb?sslmode=require"

# OpenAI API Key for semantic search embeddings
# Example: sk-proj-...
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"

# Password for accessing the admin panel dashboard
ADMIN_PASSWORD="your-secure-admin-password-here"

# The deployment URL (e.g. https://alisot.uz or your Vercel preview URL)
APP_URL="https://alisot.uz"

# Gemini API Key (Required if using Gemini AI features)
GEMINI_API_KEY="your-gemini-api-key-here"
